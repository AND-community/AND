trusted_authors.json
mod_rates.json
bootstrap.txt

# Moderasyon çıktı dosyaları — andmod tarafından oluşturulur, local.
bans/

# Konu taslakları — konu_ac eklentisi tarafından oluşturulur.
taslaklar_*.json

