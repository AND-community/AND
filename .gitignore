/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace.
go.work
go.work.sum

# Editor / OS noise.
.vscode/
.idea/
Thumbs.db
.DS_Store
.env

# Duplicate / temporary files.
*.gitignore(1)
"*.gitignore(1)"
